# Copy this file to .env.yc and fill values before running scripts/deploy-yc-coi.sh.

# Yandex Cloud CLI profile. Leave empty to use the active yc profile.
YC_PROFILE=

# Existing Yandex Container Registry ID, without cr.yandex/ prefix.
YC_REGISTRY_ID=crp00000000000000000

# Existing COI VM name. With YC_CREATE_VM=1, this is the new VM name.
YC_INSTANCE_NAME=vizitka-coi

# Optional: use VM ID instead of name for existing VM updates.
YC_INSTANCE_ID=

# Optional but recommended for existing COI VMs that pull from private Container Registry.
# If set, deploy script will attach this service account before update-container.
# YC_SERVICE_ACCOUNT_NAME=coi-puller

# Keep this stable between deploys. Generate once, for example:
# openssl rand -hex 32
JWT_SECRET=change_me_to_a_stable_secret_at_least_32_chars

# Public origin for backend CORS. If frontend and backend are same-origin via nginx /api,
# this may stay empty.
FRONTEND_URL=

# Optional image tag. Default is current git short SHA.
IMAGE_TAG=

# Weekly SQLite backup to Yandex Object Storage.
# Upload uses one stable object key, so each new backup overwrites the previous one.
BACKUP_ENABLED=1
BACKUP_S3_BUCKET=your-object-storage-bucket
BACKUP_S3_KEY=vizitka/db.sqlite
BACKUP_S3_ACCESS_KEY_ID=your-static-access-key-id
BACKUP_S3_SECRET_ACCESS_KEY=your-static-secret-access-key
BACKUP_S3_ENDPOINT_URL=https://storage.yandexcloud.net
BACKUP_S3_REGION=ru-central1
BACKUP_INTERVAL_SECONDS=604800
BACKUP_RETRY_SECONDS=300
BACKUP_RUN_ON_START=1

# Optional: build for Yandex Cloud x86_64 VMs even from Apple Silicon.
PLATFORM=linux/amd64

# Optional: create a new COI VM instead of updating an existing one.
# YC_CREATE_VM=1
# YC_ZONE=ru-central1-a
# YC_SUBNET_NAME=default-ru-central1-a
# YC_SERVICE_ACCOUNT_NAME=coi-puller
# YC_SSH_KEY=~/.ssh/id_rsa.pub
# YC_VM_CORES=2
# YC_VM_MEMORY=2GB
# YC_VM_DISK_SIZE=30GB
